# Copy to .env — used by docker compose and local uvicorn.

PUBLIC_SITE_URL=https://dev.muteeblabs.uk
# Host reverse-proxy Docker network (not related to any one app — run: docker network ls)
EDGE_PROXY_NETWORK=qubix-solutions_qubix-net
CORS_ORIGINS=https://dev.muteeblabs.uk,http://localhost:5173,http://127.0.0.1:5173
MAIL_BRAND_NAME=Muteeb Labs

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Gmail account used for SMTP auth (the actual mailbox).
EMAIL_USER=muteebworkinfo@gmail.com
# Gmail app password (16 chars, spaces OK) — generated at https://myaccount.google.com/apppasswords
EMAIL_PASS=
# Optional alias to send FROM / deliver TO. Must be verified in
# Gmail Settings → Accounts and Import → "Send mail as".
EMAIL_FROM=business@muteeblabs.uk
EMAIL_TO=business@muteeblabs.uk

# When True, the backend also sends a branded acknowledgment email
# (rendered from contact_ack_html.py) to the form submitter.
SEND_CLIENT_ACK=True
MAIL_SIGN_NAME=Muteeb Ur Rehman
MAIL_SIGN_TITLE=Full Stack Developer & AI Engineer
MAIL_REPLY_WINDOW=usually within one day

LOG_LEVEL=INFO
