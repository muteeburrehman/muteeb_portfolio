# Copy to .env — used by docker compose and local uvicorn.

# ——— Public site / TLS (Caddy edge) ———
SITE_DOMAIN=muteeblabs.com
ACME_EMAIL=info@muteeblabs.com
PUBLIC_SITE_URL=https://muteeblabs.com

CORS_ORIGINS=https://muteeblabs.com,http://localhost:5173,http://127.0.0.1:5173
MAIL_BRAND_NAME=Muteeb Labs

# Northwest Business Identity mail (MX: mailserver.businessidentity.llc)
EMAIL_HOST=mailserver.businessidentity.llc
EMAIL_PORT=25
EMAIL_USE_TLS=True
EMAIL_USER=info@muteeblabs.com
EMAIL_PASS=
EMAIL_FROM=info@muteeblabs.com
EMAIL_TO=info@muteeblabs.com

# When True, the backend also sends a branded acknowledgment email
# (rendered from contact_ack_html.py) to the form submitter.
SEND_CLIENT_ACK=True
MAIL_SIGN_NAME=Muteeb Ur Rehman
MAIL_SIGN_TITLE=Full Stack Developer & AI Engineer
MAIL_REPLY_WINDOW=usually within one day

LOG_LEVEL=INFO

# ——— Discovery call booking (/book) ———
# Required for real meeting links in confirmation emails:
MEETING_LINK=
BOOKING_TIMEZONE=America/Denver
# Pakistan time in admin booking emails only (info@muteeblabs.com) — not shown to clients.
BOOKING_ADMIN_REFERENCE_TIMEZONE=Asia/Karachi

# Optional — HubSpot free CRM (see docs/SETUP_CREDENTIALS.md)
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=

# Optional — n8n webhook on new booking
N8N_BOOKING_WEBHOOK_URL=

# Optional — legacy API stats: GET /api/booking/stats?key=...
BOOKING_ADMIN_KEY=
# Optional legacy allowlist (prefer: python scripts/create_superuser.py)
ADMIN_SUPER_EMAILS=
