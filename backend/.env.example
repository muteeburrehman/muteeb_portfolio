# Copy to backend/.env for local uvicorn (or use repo-root .env for Docker).

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Gmail account used for SMTP auth (the actual mailbox).
EMAIL_USER=muteebworkinfo@gmail.com
# Gmail app password (16 chars, spaces OK).
EMAIL_PASS=
# Optional alias to send FROM / deliver TO. Verify in Gmail → "Send mail as".
EMAIL_FROM=business@muteeblabs.uk
EMAIL_TO=business@muteeblabs.uk

# Auto-acknowledgment sent to the form submitter (set to False to disable).
SEND_CLIENT_ACK=True
MAIL_SIGN_NAME=Muteeb Ur Rehman
MAIL_SIGN_TITLE=Full Stack Developer & AI Engineer
MAIL_REPLY_WINDOW=usually within one day

PUBLIC_SITE_URL=https://dev.muteeblabs.uk
MAIL_BRAND_NAME=Muteeb Labs
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://dev.muteeblabs.uk
LOG_LEVEL=INFO
