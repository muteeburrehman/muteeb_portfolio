# Edge reverse proxy — terminates TLS and forwards to the internal web container.
# Environment variables (set in .env / docker-compose):
#   SITE_DOMAIN   e.g. muteeblabs.uk
#   ACME_EMAIL    e.g. business@muteeblabs.uk (Let's Encrypt notifications)

{
	admin off
}

{$SITE_DOMAIN:muteeblabs.uk} {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy web:80 {
		health_uri /healthz
		health_interval 30s
		health_timeout 5s

		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

www.{$SITE_DOMAIN:muteeblabs.uk} {
	redir https://{$SITE_DOMAIN:muteeblabs.uk}{uri} permanent
}

dev.muteeblabs.uk {
	redir https://{$SITE_DOMAIN:muteeblabs.uk}{uri} permanent
}
