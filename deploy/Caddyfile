# Edge reverse proxy — terminates TLS and forwards to the internal web container.
# Environment variables (set in .env / docker-compose):
#   SITE_DOMAIN   e.g. muteeblabs.com
#   ACME_EMAIL    e.g. info@muteeblabs.com (Let's Encrypt notifications)

{
	admin off
}

{$SITE_DOMAIN:muteeblabs.com} {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy web:80 {
		health_uri /healthz
		health_interval 30s
		health_timeout 5s

		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

www.{$SITE_DOMAIN:muteeblabs.com} {
	redir https://{$SITE_DOMAIN:muteeblabs.com}{uri} permanent
}

# Legacy .uk domains → primary .com site
muteeblabs.uk, www.muteeblabs.uk, dev.muteeblabs.uk {
	redir https://{$SITE_DOMAIN:muteeblabs.com}{uri} permanent
}

# n8n automation (self-hosted on same VPS)
n8n.muteeblabs.uk {
	encode gzip zstd

	reverse_proxy n8n:5678 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
